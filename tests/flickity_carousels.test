<?php
/**
 * @file
 */

/**
 * Test basic functionality.
 */
class FlickityCarouselsBasicTest extends BackdropWebTestCase {

  protected $profile = 'testing';

  /**
   * {@inheritdoc}
   */
  public function setUp() {
    parent::setUp('views_ui', 'flickity_carousels');

    // Dummy content.
    $type = $this->backdropCreateContentType();
    $this->backdropCreateNode(array('title' => 'Test content 1', 'type' => $type->type));
    $this->backdropCreateNode(array('title' => 'Test content 2', 'type' => $type->type));

    // Create and log in a user with administer views permission.
    $views_admin = $this->backdropCreateUser(array(
      'administer views',
      'access all views',
      'bypass node access',
    ));
    $this->backdropLogin($views_admin);
    return TRUE;
  }

  /**
   *
   */
  public function testAttributesCreated() {
    $path = $this->randomName(16);
    $page_title = 'My flickity page';
    $view = array();
    $view['human_name'] = $this->randomName(16);
    $view['name'] = strtolower($this->randomName(16));
    $view['description'] = $this->randomName(16);
    $view['page[create]'] = 1;
    $view['page[style][style_plugin]'] = 'flickity_carousels_default';
    $view['page[title]'] = $page_title;
    $view['page[path]'] = $path;
    $this->backdropPost('admin/structure/views/add', $view, t('Save view'));
    // Creation worked.
    $this->assertText($page_title);
    $this->assertText('Test content');
    // Check for attached scripts.
    $script_tag = $this->xpath('//script[contains(text(), :string)]', array(':string' => 'window.Backdrop'));
    $js_settings = (string) $script_tag[0];
    $expected_scripts = array(
      'modules\\\/flickity_carousels\\\/libraries\\\/flickity\\\/flickity.pkgd.min.js',
      'modules\\\/flickity_carousels\\\/js\\\/flickity-carousels.js',
    );
    foreach ($expected_scripts as $string) {
      $this->assertTrue(preg_match('#' . $string . '#', $js_settings, $matches), format_string('Script attachment found for %string', array(
        '%string' => $string,
      )));
    }
    // Find element and check attribute.
    $elements = $this->xpath('//*[contains(@class,:class)]/@data-flickity-options', array(
      ':class' => 'flickity-carousel',
    ));
    $this->assertEqual(count($elements), 1, 'Flickity carousel found on page.');
    $attribute_value = '{"resize":false,"wrapAround":false,"prevNextButtons":true,"pageDots":true,"perPage":1,"breakpoint":0,"moveBy":1,"groupCells":1,"rightToLeft":false,"cellAlign":"left"}';
    $this->assertEqual((string) $elements[0], $attribute_value, 'Data attribute has expected value');
  }

}
